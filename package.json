{
  "name": "boilerplate-gql",
  "version": "1.0.0",
  "repository": "github:lagden/boilerplate-gql",
  "description": "Boilerplate para desenvolvimento de uma API GraphQL.",
  "keywords": [
    "api",
    "graphql",
    "boilerplate"
  ],
  "main": "server/index.js",
  "type": "module",
  "files": [
    "server",
    "README.md"
  ],
  "author": "Thiago Lagden",
  "license": "MIT",
  "scripts": {
    "eslint": "eslint --config .eslintrc.yml --ext .js --ignore-path .gitignore .",
    "prettier": "prettier -c --plugin-search-dir=. ./server/**/*.js",
    "pretest": "npm run eslint",
    "test": "c8 --reporter=text --reporter=text-summary --reporter=lcov ava --serial",
    "dev": "run-s test start",
    "start": "node server"
  },
  "dependencies": {
    "@graphql-tools/graphql-file-loader": "7.3.3",
    "@graphql-tools/load": "7.4.1",
    "@graphql-tools/schema": "8.3.1",
    "@koa/router": "10.1.1",
    "@tadashi/koa-base": "5.1.0",
    "debug": "4.3.3",
    "graphql": "16.1.0",
    "koa": "2.13.4",
    "koa-bodyparser": "4.3.0",
    "koa-compose": "4.1.0",
    "local-access": "1.1.0",
    "lodash.merge": "4.6.2"
  },
  "devDependencies": {
    "@babel/core": "7.16.5",
    "@babel/eslint-parser": "7.16.5",
    "@babel/plugin-syntax-top-level-await": "7.14.5",
    "@tadashi/hex-id": "2.0.0",
    "ava": "3.15.0",
    "c8": "7.10.0",
    "eslint": "8.4.1",
    "eslint-config-xo": "0.39.0",
    "eslint-plugin-unicorn": "39.0.0",
    "got": "12.0.0",
    "hash-to-port": "1.2.0",
    "npm-run-all": "4.1.5",
    "prettier": "2.5.1"
  },
  "babel": {
    "plugins": [
      "@babel/plugin-syntax-top-level-await"
    ]
  }
}
