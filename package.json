{
  "name": "boilerplate-gql",
  "version": "1.0.0",
  "repository": "github:lagden/boilerplate-gql",
  "description": "Boilerplate para desenvolvimento de uma API GraphQL.",
  "keywords": [
    "api",
    "graphql",
    "boilerplate"
  ],
  "main": "server/index.js",
  "type": "module",
  "files": [
    "server",
    "README.md"
  ],
  "author": "Thiago Lagden",
  "license": "MIT",
  "scripts": {
    "eslint": "eslint --config .eslintrc.yml --ext .js --ignore-path .gitignore .",
    "prettier": "prettier -c --plugin-search-dir=. ./server/**/*.js",
    "pretest": "npm run eslint",
    "test": "c8 --reporter=text --reporter=text-summary --reporter=lcov ava --serial",
    "dev": "run-s test start",
    "start": "node server"
  },
  "dependencies": {
    "@graphql-tools/graphql-file-loader": "7.5.17",
    "@graphql-tools/load": "7.8.14",
    "@graphql-tools/schema": "9.0.19",
    "@koa/router": "12.0.0",
    "@tadashi/koa-base": "5.1.2",
    "@tadashi/local-access": "1.0.1",
    "debug": "4.3.4",
    "graphql": "16.6.0",
    "koa": "2.14.2",
    "koa-bodyparser": "4.4.0",
    "koa-compose": "4.1.0",
    "lodash.merge": "4.6.2"
  },
  "devDependencies": {
    "@tadashi/hex-id": "2.0.0",
    "ava": "5.2.0",
    "c8": "7.13.0",
    "eslint": "8.40.0",
    "eslint-config-xo": "0.43.1",
    "eslint-plugin-unicorn": "47.0.0",
    "got": "12.6.0",
    "hash-to-port": "1.2.0",
    "npm-run-all": "4.1.5",
    "prettier": "2.8.8"
  },
  "babel": {},
  "packageManager": "yarn@3.2.3"
}
