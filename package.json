{
  "name": "boilerplate-gql",
  "version": "1.0.0",
  "repository": "github:lagden/boilerplate-gql",
  "description": "Boilerplate para desenvolvimento de uma API GraphQL.",
  "keywords": [
    "api",
    "graphql",
    "boilerplate"
  ],
  "main": "server/index.js",
  "type": "module",
  "files": [
    "server",
    "README.md"
  ],
  "author": "Thiago Lagden",
  "license": "MIT",
  "scripts": {
    "eslint": "eslint --ignore-path .gitignore .",
    "pretest": "npm run eslint",
    "test": "c8 --reporter=text --reporter=text-summary --reporter=lcov --reporter=cobertura ava",
    "dev": "run-s test start",
    "start": "node server"
  },
  "dependencies": {
    "@graphql-tools/load-files": "7.0.0",
    "@koa/router": "12.0.0",
    "@tadashi/debug": "4.0.0",
    "@tadashi/koa-base": "5.1.2",
    "@tadashi/local-access": "1.1.0",
    "graphql": "16.8.1",
    "graphql-scalars": "1.22.2",
    "graphql-yoga": "4.0.4",
    "koa": "2.14.2",
    "koa-bodyparser": "4.4.1",
    "koa-compose": "4.1.0",
    "lodash.merge": "4.6.2"
  },
  "devDependencies": {
    "@tadashi/hex-id": "3.0.2",
    "ava": "5.3.1",
    "c8": "8.0.1",
    "eslint": "8.50.0",
    "eslint-plugin-unicorn": "48.0.1",
    "got": "13.0.0",
    "hash-to-port": "1.2.0",
    "npm-run-all": "4.1.5"
  }
}
