    "@tadashi/ee": "1.0.0",
    "@tadashi/koa-base": "5.2.0",
    "@tadashi/local-access": "1.1.1",
    "@xet/log-google": "1.0.0",
    "graphql": "16.8.1",
    "graphql-scalars": "1.22.4",
    "graphql-yoga": "5.0.0",
    "koa": "2.14.2",
    "koa-bodyparser": "4.4.1",
    "koa-compose": "4.1.0",
    "lodash.merge": "4.6.2"
  },
  "devDependencies": {
    "@tadashi/hex-id": "3.0.2",
